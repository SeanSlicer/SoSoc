# Base URL of the sosoc web backend. Must be reachable from your device.
# For iOS simulator: http://localhost:3000
# For a physical device on your LAN: http://<machine-lan-ip>:3000
EXPO_PUBLIC_API_URL="http://localhost:3000"

# Supabase — same values as the web app's NEXT_PUBLIC_SUPABASE_URL and
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
EXPO_PUBLIC_SUPABASE_URL=""
EXPO_PUBLIC_SUPABASE_ANON_KEY=""
