// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

enum UserRole {
    ADMIN
    USER
}

enum NotificationType {
    NEW_FOLLOWER
    NEW_MESSAGE
    FRIEND_REQUEST
    NEW_LIKE
    NEW_COMMENT
    FOLLOW_REQUEST
    FOLLOW_REQUEST_ACCEPTED
}

enum PostType {
    PHOTO
    CAPTION
    VIDEO
}

model User {
    id              String    @id @default(cuid())
    username        String    @unique
    email           String    @unique
    emailVerified   DateTime?
    password        String
    role            UserRole  @default(USER)
    photo           String?   @default("default.png")
    bannerUrl       String?
    bio             String?
    displayName     String?
    isPrivate       Boolean   @default(false)
    hideFollowLists Boolean   @default(false)
    createdAt       DateTime  @default(now()) @map(name: "created_at")
    updatedAt       DateTime  @default(now()) @map(name: "updated_at")

    followers              User[]               @relation(name: "Followers")
    follows                User[]               @relation(name: "Followers")
    notifications          Notification[]       @relation("NotificationRecipient")
    triggeredNotifications Notification[]       @relation("NotificationActor")
    posts                  Post[]
    likes                  Like[]
    comments               Comment[]
    sentFollowRequests     FollowRequest[]      @relation("SentRequests")
    receivedFollowRequests FollowRequest[]      @relation("ReceivedRequests")
    conversations          ConversationMember[]
    sentMessages           Message[]            @relation("SentMessages")
    passwordResetTokens    PasswordResetToken[]
    emailVerificationTokens EmailVerificationToken[]

    @@map(name: "users")
}

model FollowRequest {
    id          String   @id @default(cuid())
    createdAt   DateTime @default(now()) @map(name: "created_at")
    requesterId String
    targetId    String

    requester User @relation("SentRequests", fields: [requesterId], references: [id])
    target    User @relation("ReceivedRequests", fields: [targetId], references: [id])

    @@unique([requesterId, targetId])
    @@index([requesterId])
    @@index([targetId])
    @@map(name: "follow_requests")
}

model Post {
    id        String   @id @default(cuid())
    content   String
    type      PostType
    imageUrl  String?
    images    String[] @default([])
    videoUrl  String?
    createdAt DateTime @default(now()) @map(name: "created_at")
    updatedAt DateTime @default(now()) @map(name: "updated_at")

    author           User      @relation(fields: [authorId], references: [id])
    authorId         String
    likes            Like[]
    comments         Comment[]
    sharedInMessages Message[] @relation("SharedInMessages")

    @@index([authorId])
    @@map(name: "posts")
}

model Conversation {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now()) @map(name: "created_at")
    updatedAt DateTime @updatedAt @map(name: "updated_at")
    name      String?

    members  ConversationMember[]
    messages Message[]

    @@map(name: "conversations")
}

model ConversationMember {
    userId         String
    conversationId String
    lastReadAt     DateTime? @map(name: "last_read_at")

    user         User         @relation(fields: [userId], references: [id])
    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

    @@id([userId, conversationId])
    @@index([userId])
    @@map(name: "conversation_members")
}

model Message {
    id             String   @id @default(cuid())
    createdAt      DateTime @default(now()) @map(name: "created_at")
    content        String?
    senderId       String
    conversationId String
    sharedPostId   String?

    sender       User         @relation("SentMessages", fields: [senderId], references: [id])
    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    sharedPost   Post?        @relation("SharedInMessages", fields: [sharedPostId], references: [id], onDelete: SetNull)

    @@index([conversationId, createdAt])
    @@index([senderId])
    @@map(name: "messages")
}

model Notification {
    id        String           @id @default(cuid())
    createdAt DateTime         @default(now()) @map(name: "created_at")
    updatedAt DateTime         @updatedAt @map(name: "updated_at")
    content   String
    userId    String
    actorId   String?
    postId    String?

    user   User             @relation("NotificationRecipient", fields: [userId], references: [id])
    actor  User?            @relation("NotificationActor", fields: [actorId], references: [id])
    type   NotificationType
    isRead Boolean          @default(false)

    @@index([userId])
    @@map(name: "notifications")
}

model PasswordResetToken {
    id        String    @id @default(cuid())
    userId    String
    tokenHash String    @unique
    expiresAt DateTime
    usedAt    DateTime?
    createdAt DateTime  @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("password_reset_tokens")
}

model EmailVerificationToken {
    id        String   @id @default(cuid())
    userId    String
    tokenHash String   @unique
    expiresAt DateTime
    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("email_verification_tokens")
}

model Like {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now()) @map(name: "created_at")

    user   User   @relation(fields: [userId], references: [id], map: "UserLikes")
    userId String

    post   Post   @relation(fields: [postId], references: [id], map: "PostLikes")
    postId String

    @@unique([userId, postId])
    @@index([userId])
    @@index([postId])
    @@map(name: "likes")
}

model Comment {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now()) @map(name: "created_at")

    content String

    user   User   @relation(fields: [userId], references: [id], map: "UserComments")
    userId String

    post   Post   @relation(fields: [postId], references: [id], map: "PostComments")
    postId String

    @@index([userId])
    @@index([postId])
    @@map(name: "comments")
}
