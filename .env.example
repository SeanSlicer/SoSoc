# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
#
# On Supabase, use the *pooler* (PgBouncer) URL for DATABASE_URL and the direct URL for DIRECT_URL.
# Pooler port is 6543; append ?pgbouncer=true&connection_limit=1 for serverless environments (Vercel).
# Find both URLs in: Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres"

# Auth
JWT_SECRET_KEY=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# Found in Supabase dashboard → Settings → API → service_role key (keep this secret — server only)
SUPABASE_SERVICE_ROLE_KEY=""

# CORS — comma-separated list of origins that may hit /api/trpc and /api/auth/mobile-*.
# Production web and mobile share the same domain, so this is a dev-only setting.
# In development, localhost and LAN IPs are allowed automatically.
# CORS_ALLOWED_ORIGINS="http://localhost:8081,exp://192.168.1.10:8081"
